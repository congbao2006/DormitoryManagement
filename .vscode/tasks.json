{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "Run Backend API",
			"type": "shell",
			"command": "dotnet",
			"args": [
				"run",
				"--project",
				"QuanLyKyTucXa.API/QuanLyKyTucXa.API.csproj",
				"--urls",
				"http://localhost:5000"
			],
			"isBackground": true,
			"group": "build"
		},
		{
			"label": "Run Frontend Node",
			"type": "shell",
			"command": "npm",
			"args": [
				"run",
				"dev",
				"--prefix",
				"frontend-node"
			],
			"isBackground": true,
			"group": "build"
		}
	]
}