<%- include('../partials/header') %>

<h2 class="mb-3 crud-title">Quản lý Yêu cầu sửa chữa</h2>

<form class="row g-2 mb-4 crud-form" method="post" action="/yeucau">
  <div class="col-md-2"><input class="form-control" name="maYeuCau" placeholder="Mã YC" required /></div>
  <% if (currentUser && currentUser.role !== 'SinhVien') { %>
  <div class="col-md-2"><input class="form-control" name="maSinhVien" placeholder="Mã Sinh viên" required /></div>
  <% } %>
  <div class="col-md-5"><input class="form-control" name="moTa" placeholder="Mo ta" required /></div>
  <div class="col-md-3"><input class="form-control" type="date" name="ngayYeuCau" required /></div>
  <div class="col-md-2"><input class="form-control" name="trangThai" value="DaGui" required /></div>
  <div class="col-12"><button class="btn btn-primary">Thêm Yêu cầu</button></div>
</form>

<div class="table-responsive crud-table-wrap">
  <table class="table table-striped table-hover">
    <thead><tr><th>Mã</th><th>Mo ta</th><th>Ngày yeu cau</th><th>Trạng thái</th><th>Thao tác</th></tr></thead>
    <tbody>
      <% items.forEach(i => { %>
      <tr>
        <td><%= i.maYeuCau %></td>
        <td><%= i.moTa %></td>
        <td><%= new Date(i.ngayYeuCau).toLocaleDateString('vi-VN') %></td>
        <td><%= i.trangThai %></td>
        <td>
          <% if (!currentUser || currentUser.role !== 'SinhVien') { %>
          <a class="btn btn-sm btn-outline-primary me-2" href="/yeucau/<%= i.maYeuCau %>/edit">Sửa</a>
          <form method="post" action="/yeucau/<%= i.maYeuCau %>/delete">
            <button class="btn btn-sm btn-outline-danger">Xóa</button>
          </form>
          <% } %>
        </td>
      </tr>
      <% }) %>
    </tbody>
  </table>
</div>

<%- include('../partials/footer') %>
