<%- include('../partials/header') %>

<h2 class="mb-3 crud-title">Quản lý Hóa đơn</h2>

<% if (!currentUser || currentUser.role !== 'SinhVien') { %>
<form class="row g-2 mb-4 crud-form" method="post" action="/hoadon">
  <div class="col-md-2"><input class="form-control" name="maHoaDon" placeholder="MaHoaDon" required /></div>
  <div class="col-md-3"><input class="form-control" type="date" name="ngayThanhToan" required /></div>
  <div class="col-md-3"><input class="form-control" name="tongTien" placeholder="Tổng tiền" required /></div>
  <div class="col-md-2"><input class="form-control" name="trangThai" value="ChuaThanhToan" required /></div>
  <div class="col-12"><button class="btn btn-primary">Thêm Hóa đơn</button></div>
</form>
<% } %>

<div class="table-responsive crud-table-wrap">
  <table class="table table-striped table-hover">
    <thead><tr><th>Mã</th><th>Ngày thanh toán</th><th>Tổng tiền</th><th>Trạng thái</th><th>Thao tác</th></tr></thead>
    <tbody>
      <% items.forEach(i => { %>
      <tr>
        <td><%= i.maHoaDon %></td>
        <td><%= new Date(i.ngayThanhToan).toLocaleDateString('vi-VN') %></td>
        <td><%= i.tongTien %></td>
        <td><%= i.trangThai %></td>
        <td>
          <% if (!currentUser || currentUser.role !== 'SinhVien') { %>
          <a class="btn btn-sm btn-outline-primary me-2" href="/hoadon/<%= i.maHoaDon %>/edit">Sửa</a>
          <form method="post" action="/hoadon/<%= i.maHoaDon %>/delete">
            <button class="btn btn-sm btn-outline-danger">Xóa</button>
          </form>
          <% } %>
        </td>
      </tr>
      <% }) %>
    </tbody>
  </table>
</div>

<%- include('../partials/footer') %>
