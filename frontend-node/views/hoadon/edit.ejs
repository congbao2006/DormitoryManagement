<%- include('../partials/header') %>

<h2 class="mb-3 crud-title">Cập nhật Hóa đơn</h2>

<form class="row g-2 mb-4 crud-form" method="post" action="/hoadon/<%= item.maHoaDon %>/edit">
  <div class="col-md-2"><input class="form-control" value="<%= item.maHoaDon %>" disabled /></div>
  <div class="col-md-3"><input class="form-control" type="date" name="ngayThanhToan" value="<%= item.ngayThanhToan ? item.ngayThanhToan.split('T')[0] : '' %>" required /></div>
  <div class="col-md-3"><input class="form-control" name="tongTien" value="<%= item.tongTien %>" required /></div>
  <div class="col-md-2"><input class="form-control" name="trangThai" value="<%= item.trangThai %>" required /></div>
  <div class="col-12 d-flex gap-2"><button class="btn btn-primary">Lưu</button><a class="btn btn-outline-secondary" href="/hoadon">Hủy</a></div>
</form>

<%- include('../partials/footer') %>