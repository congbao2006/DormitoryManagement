<%- include('../partials/header') %>

<section class="hero mx-auto auth-shell" style="max-width: 560px;">
  <h1 class="h3 mb-2">Đăng nhập hệ thống</h1>
  <p class="text-muted mb-4">Nhập email và mật khẩu để truy cập portal quản lý ký túc xá.</p>

  <% if (error) { %>
    <div class="alert alert-danger"><%= error %></div>
  <% } %>

  <% if (success) { %>
    <div class="alert alert-success"><%= success %></div>
  <% } %>

  <form method="post" action="/login" class="row g-3 auth-form">
    <div class="col-12">
      <label class="form-label">Email</label>
      <input class="form-control" name="email" type="email" value="<%= form?.email || '' %>" required />
    </div>
    <div class="col-12">
      <label class="form-label">Mật khẩu</label>
      <input class="form-control" name="matKhau" type="password" required />
    </div>
    <div class="col-12 d-grid">
      <button class="btn btn-primary w-100">Đăng nhập</button>
    </div>
    <div class="col-12 text-center small text-muted">
      Chưa có tài khoản?
      <a href="/register" class="auth-link">Đăng ký ngay</a>
    </div>
  </form>
</section>

<%- include('../partials/footer') %>
