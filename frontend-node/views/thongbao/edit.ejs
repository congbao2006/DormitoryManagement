<%- include('../partials/header') %>

<h2 class="mb-3 crud-title">Cập nhật Thông báo</h2>

<form class="row g-2 mb-4 crud-form" method="post" action="/thongbao/<%= item.maThongBao %>/edit">
  <div class="col-md-2"><input class="form-control" value="<%= item.maThongBao %>" disabled /></div>
  <div class="col-md-4"><input class="form-control" name="tieuDe" value="<%= item.tieuDe %>" required /></div>
  <div class="col-md-4"><input class="form-control" name="noiDung" value="<%= item.noiDung %>" required /></div>
  <div class="col-md-2"><input class="form-control" type="date" name="ngayTao" value="<%= item.ngayTao ? item.ngayTao.split('T')[0] : '' %>" required /></div>
  <div class="col-12 d-flex gap-2"><button class="btn btn-primary">Lưu</button><a class="btn btn-outline-secondary" href="/thongbao">Hủy</a></div>
</form>

<%- include('../partials/footer') %>