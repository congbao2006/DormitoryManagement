<%- include('../partials/header') %>

<h2 class="mb-3 crud-title">Quản lý Thông báo</h2>

<form class="row g-2 mb-4 crud-form" method="post" action="/thongbao">
  <div class="col-md-2"><input class="form-control" name="maThongBao" placeholder="Mã TB" required /></div>
  <div class="col-md-4"><input class="form-control" name="tieuDe" placeholder="Tiêu đề" required /></div>
  <div class="col-md-4"><input class="form-control" name="noiDung" placeholder="Nội dung" required /></div>
  <div class="col-md-2"><input class="form-control" type="date" name="ngayTao" required /></div>
  <div class="col-12"><button class="btn btn-primary">Thêm Thông báo</button></div>
</form>

<div class="table-responsive crud-table-wrap">
  <table class="table table-striped table-hover">
    <thead><tr><th>Mã</th><th>Tiêu đề</th><th>Nội dung</th><th>Ngày tao</th><th>Thao tác</th></tr></thead>
    <tbody>
      <% items.forEach(i => { %>
      <tr>
        <td><%= i.maThongBao %></td>
        <td><%= i.tieuDe %></td>
        <td><%= i.noiDung %></td>
        <td><%= new Date(i.ngayTao).toLocaleDateString('vi-VN') %></td>
        <td>
          <a class="btn btn-sm btn-outline-primary me-2" href="/thongbao/<%= i.maThongBao %>/edit">Sửa</a>
          <form method="post" action="/thongbao/<%= i.maThongBao %>/delete">
            <button class="btn btn-sm btn-outline-danger">Xóa</button>
          </form>
        </td>
      </tr>
      <% }) %>
    </tbody>
  </table>
</div>

<%- include('../partials/footer') %>
