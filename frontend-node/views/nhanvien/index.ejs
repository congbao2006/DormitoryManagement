<%- include('../partials/header') %>

<h2 class="mb-3 crud-title">Quản lý Nhân viên</h2>

<form class="row g-2 mb-4 crud-form" method="post" action="/nhanvien">
  <div class="col-md-2"><input class="form-control" name="maNhanVien" placeholder="MaNV" required /></div>
  <div class="col-md-3"><input class="form-control" name="hoTen" placeholder="Họ tên" required /></div>
  <div class="col-md-2"><input class="form-control" type="date" name="ngaySinh" required /></div>
  <div class="col-md-1"><input class="form-control" name="gioiTinh" placeholder="GT" required /></div>
  <div class="col-md-2"><input class="form-control" name="soDienThoai" placeholder="SDT" required /></div>
  <div class="col-md-2"><input class="form-control" name="email" placeholder="Email" required /></div>
  <div class="col-md-2"><input class="form-control" name="cccd" placeholder="CCCD" required /></div>
  <div class="col-md-2"><input class="form-control" name="trangThai" value="DangLamViec" required /></div>
  <div class="col-12"><button class="btn btn-primary">Thêm Nhân viên</button></div>
</form>

<div class="table-responsive crud-table-wrap">
  <table class="table table-striped table-hover">
    <thead><tr><th>Mã</th><th>Họ tên</th><th>Email</th><th>SDT</th><th>Trạng thái</th><th>Thao tác</th></tr></thead>
    <tbody>
      <% items.forEach(i => { %>
      <tr>
        <td><%= i.maNhanVien %></td>
        <td><%= i.hoTen %></td>
        <td><%= i.email %></td>
        <td><%= i.soDienThoai %></td>
        <td><%= i.trangThai %></td>
        <td>
          <a class="btn btn-sm btn-outline-primary me-2" href="/nhanvien/<%= i.maNhanVien %>/edit">Sửa</a>
          <form method="post" action="/nhanvien/<%= i.maNhanVien %>/delete">
            <button class="btn btn-sm btn-outline-danger">Xóa</button>
          </form>
        </td>
      </tr>
      <% }) %>
    </tbody>
  </table>
</div>

<%- include('../partials/footer') %>
