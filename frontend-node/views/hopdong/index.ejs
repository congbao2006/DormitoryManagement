<%- include('../partials/header') %>

<h2 class="mb-3 crud-title">Quản lý Hợp đồng</h2>

<% if (!currentUser || currentUser.role !== 'SinhVien') { %>
<form class="row g-2 mb-4 crud-form" method="post" action="/hopdong">
  <div class="col-md-2"><input class="form-control" name="maHopDong" placeholder="Mã HĐ" required /></div>
  <div class="col-md-2">
    <select class="form-select" name="maSinhVien" required>
      <option value="">Chọn SV</option>
      <% (sinhViens || []).forEach(sv => { %>
      <option value="<%= sv.maSinhVien %>"><%= sv.maSinhVien %> - <%= sv.hoTen %></option>
      <% }) %>
    </select>
  </div>
  <div class="col-md-2">
    <select class="form-select" name="maPhong" required>
      <option value="">Chọn phòng</option>
      <% (phongs || []).forEach(phong => { %>
      <option value="<%= phong.maPhong %>"><%= phong.maPhong %> - <%= phong.soPhong %></option>
      <% }) %>
    </select>
  </div>
  <div class="col-md-2"><input class="form-control" type="date" name="ngayBatDau" required /></div>
  <div class="col-md-2"><input class="form-control" type="date" name="ngayKetThuc" required /></div>
  <div class="col-md-1"><input class="form-control" name="tienDatCoc" placeholder="Cọc" required /></div>
  <div class="col-md-1"><input class="form-control" name="trangThai" value="HieuLuc" required /></div>
  <div class="col-12"><button class="btn btn-primary">Thêm Hợp đồng</button></div>
</form>
<% } %>

<div class="table-responsive crud-table-wrap">
  <table class="table table-striped table-hover">
    <thead><tr><th>Mã</th><th>Mã SV</th><th>Mã phòng</th><th>Ngày bắt đầu</th><th>Ngày kết thúc</th><th>Tiền đặt cọc</th><th>Trạng thái</th><th>Thao tác</th></tr></thead>
    <tbody>
      <% items.forEach(i => { %>
      <tr>
        <td><%= i.maHopDong %></td>
        <td><%= i.maSinhVien %></td>
        <td><%= i.maPhong %></td>
        <td><%= new Date(i.ngayBatDau).toLocaleDateString('vi-VN') %></td>
        <td><%= new Date(i.ngayKetThuc).toLocaleDateString('vi-VN') %></td>
        <td><%= i.tienDatCoc %></td>
        <td><%= i.trangThai %></td>
        <td>
          <% if (!currentUser || currentUser.role !== 'SinhVien') { %>
          <a class="btn btn-sm btn-outline-primary me-2" href="/hopdong/<%= i.maHopDong %>/edit">Sửa</a>
          <form method="post" action="/hopdong/<%= i.maHopDong %>/delete">
            <button class="btn btn-sm btn-outline-danger">Xóa</button>
          </form>
          <% } %>
        </td>
      </tr>
      <% }) %>
    </tbody>
  </table>
</div>

<%- include('../partials/footer') %>
