<!DOCTYPE html>
<html lang="vi">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= title || 'Quản Lý Ký Túc Xá' %></title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700&family=IBM+Plex+Serif:wght@500;600&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@fortawesome/fontawesome-free@6.7.2/css/all.min.css" />
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/admin-lte@3.2/dist/css/adminlte.min.css" />
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
  <link rel="stylesheet" href="/css/app.css" />
</head>
<body class="hold-transition sidebar-mini layout-fixed layout-navbar-fixed">
  <% const isActive = (prefixes) => prefixes.some((prefix) => prefix === '/' ? currentPath === '/' : currentPath === prefix || currentPath.startsWith(prefix + '/')); %>
  <% if (currentUser) { %>
  <% const role = currentUser.role; %>
  <div class="wrapper">
    <nav class="main-header navbar navbar-expand navbar-light navbar-white border-bottom-0 app-topbar">
      <ul class="navbar-nav">
        <li class="nav-item">
          <a class="nav-link" data-widget="pushmenu" href="#" role="button"><i class="fas fa-bars"></i></a>
        </li>
      </ul>
      <ul class="navbar-nav ml-auto d-flex align-items-center gap-2">
        <li class="nav-item user-chip"><%= currentUser.hoTen %> · <%= currentUser.role %></li>
        <li class="nav-item">
          <form method="post" action="/logout" class="m-0">
            <button class="btn btn-sm btn-outline-secondary" type="submit">Đăng xuất</button>
          </form>
        </li>
      </ul>
    </nav>

    <aside class="main-sidebar sidebar-dark-primary elevation-3 app-sidebar">
      <a href="/" class="brand-link">
        <span class="brand-image img-circle elevation-2 d-flex align-items-center justify-content-center">
          <i class="fas fa-building"></i>
        </span>
        <span class="brand-text font-weight-light">Ký Túc Xá Portal</span>
      </a>

      <div class="sidebar">
        <nav class="mt-2">
          <ul class="nav nav-pills nav-sidebar flex-column" data-widget="treeview" role="menu" data-accordion="false">
            <li class="nav-item">
              <a href="/" class="nav-link <%= isActive(['/']) ? 'active' : '' %>">
                <i class="nav-icon fas fa-gauge-high"></i>
                <p>Bảng điều khiển</p>
              </a>
            </li>
            <li class="nav-item">
              <a href="/sinhvien" class="nav-link <%= isActive(['/sinhvien']) ? 'active' : '' %>">
                <i class="nav-icon fas fa-user-graduate"></i>
                <p>Sinh viên</p>
              </a>
            </li>
            <% if (role === 'Admin') { %>
            <li class="nav-item">
              <a href="/nhanvien" class="nav-link <%= isActive(['/nhanvien']) ? 'active' : '' %>">
                <i class="nav-icon fas fa-users-gear"></i>
                <p>Nhân viên</p>
              </a>
            </li>
            <% } %>
            <% if (role === 'Admin' || role === 'NhanVien') { %>
            <li class="nav-item">
              <a href="/phong" class="nav-link <%= isActive(['/phong']) ? 'active' : '' %>">
                <i class="nav-icon fas fa-door-open"></i>
                <p>Phòng</p>
              </a>
            </li>
            <li class="nav-item">
              <a href="/toanha" class="nav-link <%= isActive(['/toanha']) ? 'active' : '' %>">
                <i class="nav-icon fas fa-city"></i>
                <p>Tòa nhà</p>
              </a>
            </li>
            <% } %>
            <li class="nav-item">
              <a href="/hopdong" class="nav-link <%= isActive(['/hopdong']) ? 'active' : '' %>">
                <i class="nav-icon fas fa-file-signature"></i>
                <p>Hợp đồng</p>
              </a>
            </li>
            <li class="nav-item">
              <a href="/hoadon" class="nav-link <%= isActive(['/hoadon']) ? 'active' : '' %>">
                <i class="nav-icon fas fa-file-invoice-dollar"></i>
                <p>Hóa đơn</p>
              </a>
            </li>
            <% if (role === 'Admin' || role === 'NhanVien') { %>
            <li class="nav-item">
              <a href="/thongbao" class="nav-link <%= isActive(['/thongbao']) ? 'active' : '' %>">
                <i class="nav-icon fas fa-bullhorn"></i>
                <p>Thông báo</p>
              </a>
            </li>
            <% } %>
            <li class="nav-item">
              <a href="/yeucau" class="nav-link <%= isActive(['/yeucau']) ? 'active' : '' %>">
                <i class="nav-icon fas fa-screwdriver-wrench"></i>
                <p>Yêu cầu</p>
              </a>
            </li>
            <% if (role === 'Admin' || role === 'NhanVien') { %>
            <li class="nav-item">
              <a href="/taisan" class="nav-link <%= isActive(['/taisan']) ? 'active' : '' %>">
                <i class="nav-icon fas fa-toolbox"></i>
                <p>Tài sản</p>
              </a>
            </li>
            <% } %>
            <li class="nav-item">
              <a href="/thanhtoan" class="nav-link <%= isActive(['/thanhtoan']) ? 'active' : '' %>">
                <i class="nav-icon fas fa-wallet"></i>
                <p>Thanh toán</p>
              </a>
            </li>
          </ul>
        </nav>
      </div>
    </aside>

    <div class="content-wrapper app-content-wrap">
      <section class="content pt-3">
        <div class="container-fluid app-content">
  <% } else { %>
  <div class="app-auth-page">
    <main class="container py-4 py-lg-5">
  <% } %>
